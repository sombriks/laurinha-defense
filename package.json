{
  "type": "module",
  "name": "laurinha-defense",
  "version": "1.0.0",
  "description": "Tower defense da minha sombrinha",
  "author": "Leronardo Silveira",
  "license": "MIT",
  "keywords": [
    "parcel",
    "phaser"
  ],
  "scripts": {
    "dev": "parcel src/index.html",
    "predev": "rm -rf .parcel-cache dist",
    "build": "parcel build --dist-dir dist src/index.html",
    "prebuild": "rm -rf dist",
    "build:gh": "parcel build --dist-dir dist --public-url /laurinha-defense src/index.html"
  },
  "devDependencies": {
    "@parcel/packager-raw-url": "^2.16.4",
    "@parcel/transformer-webmanifest": "^2.16.4",
    "matter-js": "^0.20.0",
    "parcel": "^2.16.4",
    "phaser": "^4.1.0",
    "process": "^0.11.10"
  }
}
